# Environment Variables Template
# Copy this file to .env and set your actual values
# cp env.development .env
# Then edit .env with your real values

# Database Configuration
POSTGRES_HOST=db
POSTGRES_USER=dol_user
POSTGRES_PASSWORD=artygenz
POSTGRES_DB=dol_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://dol_user:artygenz@db:5432/dol_db

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# Email Configuration (REQUIRED - Set these values)
IMAP_HOST=lumenlighthouse.ai
IMAP_PORT=993
IMAP_USERNAME=your_imap_username@lumenlighthouse.ai
IMAP_PASSWORD=your_imap_password

SMTP_HOST=lumenlighthouse.ai
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username@lumenlighthouse.ai
SMTP_PASSWORD=your_smtp_password
EMAIL_USER=your_email@lumenlighthouse.ai
EMAIL_PASS=your_email_password
PMO_EMAIL_ADDRESS=kevin.brown@lumenlighthouse.ai

# OpenAI Configuration (REQUIRED - Set this value)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1

# Application Configuration (REQUIRED - Set this value)
JWT_SECRET=your_secure_jwt_secret_here
APP_LOG_DIR=/app/logs
OUTBOX_DIR=/tmp/outbox
LOG_LEVEL=INFO

# Email Webhook
EMAIL_WEBHOOK_ENDPOINT=http://localhost:8000/api/email/webhook

# Python Configuration
PYTHONUNBUFFERED=1
PYTHONPATH=/app

# Optional AWS Configuration (if using S3)
# AWS_S3_BUCKET=your_bucket_name
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1

# Optional Email Configuration
IMAP_MAILBOX=INBOX
IMAP_CHECK_INTERVAL=30
IMAP_MAX_RETRIES=5
IMAP_RETRY_DELAY=60
IMAP_IDLE_TIMEOUT=30

# Optional Application Features
ENABLE_FILE_LOGGING=true
ENABLE_LLM_FALLBACK=true
